{
  "id": "discussions",
  "name": "Discussions",
  "version": "0.1.0",
  "description": "提供主题讨论 API、前端路由、讨论列表过滤排序和讨论生命周期界面；基础讨论数据由 content 提供。",
  "icon": "fas fa-comments",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "users",
    "content"
  ],
  "provides": [
    "discussion-api",
    "discussion-ui",
    "discussion_lifecycle"
  ],
  "django": {
    "app_config": "bias_ext_discussions.backend.apps.DiscussionsExtensionConfig",
    "app_label": "discussions",
    "migration_module": "bias_ext_discussions.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_discussions.backend.ext"
  },
  "frontend": {
    "admin_entry": "frontend/admin/index.js",
    "forum_entry": "frontend/forum/index.js"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  },
  "security": {
    "capabilities_notice": "Discussion UI/API wrapper; delegates discussion records to the content foundation and contributes visibility, sorting, lifecycle, and moderation surfaces."
  }
}
